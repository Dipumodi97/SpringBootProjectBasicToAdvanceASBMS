package com.dipu.beans;

public class Car {

	private IEngine engine;
	
	public void setEngine(IEngine engine) {
		this.engine = engine;
	}
	
	public Car() {
		System.out.println("Car :: Constructor");
	}
	public void drive() {
		int start = engine.start();
		
		if(start >=1) {
			System.out.println("Journey Started...");
		}else {
			System.out.println("Trouble");
		}
	}
}
